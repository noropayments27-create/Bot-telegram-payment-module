NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgres://telegram:telegram@localhost:5432/telegram_sales
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# Client/API authentication
BOT_TO_API_SECRET=change-this-shared-secret
ADMIN_API_KEY=change-this-admin-api-key

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_TOKEN_SECRET=change-this-long-admin-token-secret
ADMIN_TELEGRAM_IDS=
ADMIN_ORIGIN=http://localhost:3000

# Telegram integration
TELEGRAM_BOT_TOKEN=
BOT_USERNAME=
TELEGRAM_BOT_USERNAME=

# Payment destinations
NEQUI_NUMBER=
NEQUI_NAME=
BINANCE_ID=
MERCADOPAGO_ACCOUNT=
PAYPAL_ACCOUNT=
CRYPTO_WALLET_BTC=
CRYPTO_WALLET_LTC=
CRYPTO_WALLET_USDT_TRON=
CRYPTO_WALLET_USDT_BSC=

# Payment proof OCR
PAYMENT_PROOF_OCR_ENABLED=true
PAYMENT_PROOF_OCR_STRICT=false
PAYMENT_PROOF_OCR_TIMEOUT_MS=45000
PAYMENT_PROOF_OCR_LANGS=spa+eng

# Order expiry
ORDER_EXPIRY_MINUTES=60
ORDER_EXPIRY_INTERVAL_MS=60000
ORDER_EXPIRY_NOTIFY_TELEGRAM=true

# Delivery pacing
DELIVERY_INITIAL_DELAY_MS=10000
DELIVERY_MESSAGE_INTERVAL_MS=1000

# Wallet jobs
WALLET_SYNC_THROTTLE_MS=30000
WALLET_SYNC_BATCH_LIMIT=50

# Optional operational features
API_LOG_REQUESTS=true
API_RATE_LIMIT_ENABLED=true
BACKUP_TELEGRAM_ENABLED=false
BACKUP_DRIVE_ENABLED=false
OPS_ALERTS_ENABLED=false
